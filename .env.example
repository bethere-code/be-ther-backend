NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# MongoDB connection string (local Docker or Atlas).
# Local example: mongodb://127.0.0.1:27017/be_ther
MONGODB_URI=mongodb://127.0.0.1:27017/be_ther

# API rate limit (per IP per minute window in Fastify plugin).
RATE_LIMIT_MAX=200

# JWT secrets (use long random strings in production).
JWT_ACCESS_SECRET=change_me_access_secret_min_16_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_16_chars
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# Google Sign-In: Web client ID from Google Cloud Console (OAuth 2.0 → Web application).
# Replace with your real client ID; the value below is a placeholder shape only (OTP still works if Flutter leaves Google disabled).
GOOGLE_WEB_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# OTP email via Brevo SMTP (https://app.brevo.com/).
OTP_DEV_LOG=true
OTP_TTL_MIN=10
OTP_MAX_ATTEMPTS=5
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=accounts@be-ther.com
BREVO_SMTP_PASSWORD=bsk72VM8M5pJu4G
EMAIL_FROM=noreply@yourdomain.com

# Media: local disk (dev) or Cloudflare R2 (S3-compatible).
MEDIA_STORAGE=local
PUBLIC_BASE_URL=http://127.0.0.1:3000
# Public web origin for share links / Open Graph previews (no trailing slash).
SHARE_WEB_BASE_URL=https://be-ther.com

# When MEDIA_STORAGE=r2, set these (see Cloudflare R2 dashboard):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=https://your-public-r2-host
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
