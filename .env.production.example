NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Docker network hostname for Mongo service in docker-compose.prod.yml
MONGODB_URI=mongodb://mongodb:27017/be_ther
RATE_LIMIT_MAX=200

# Use long random values (32+ chars recommended)
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# Google auth (required by env validation)
GOOGLE_WEB_CLIENT_ID=replace_with_google_web_client_id.apps.googleusercontent.com

OTP_DEV_LOG=false
OTP_TTL_MIN=10
OTP_MAX_ATTEMPTS=5

BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=replace_with_brevo_user
BREVO_SMTP_PASSWORD=replace_with_brevo_password
EMAIL_FROM=noreply@be-ther.com

# Media storage: local or r2
MEDIA_STORAGE=r2
PUBLIC_BASE_URL=https://be-ther.com/api

# Required when MEDIA_STORAGE=r2
R2_ACCOUNT_ID=replace_with_r2_account_id
R2_ACCESS_KEY_ID=replace_with_r2_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_r2_secret_access_key
R2_BUCKET=replace_with_r2_bucket
R2_PUBLIC_BASE_URL=https://replace_with_public_r2_url
R2_ENDPOINT=https://replace_with_accountid.r2.cloudflarestorage.com
